# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Google Analytics (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── AI API keys (optional – users can also enter their own in the UI) ────────
NEXT_PUBLIC_ANTHROPIC_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLOUD_TTS_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Create a Clerk app at https://clerk.com and copy the keys from the dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com and copy the connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=interviews

# ── Admin bootstrap (optional, one-time setup) ───────────────────────────────
# Set this to a Clerk userId to allow that account to call POST /api/admin/bootstrap
# and become the first admin when no admin exists yet.
ADMIN_BOOTSTRAP_USER_ID=

# ── Scheduled question discovery (optional) ───────────────────────────────────
# Required for Vercel Cron to call /api/cron/questions.
CRON_SECRET=8b6a9df2f0d14c8fbf7f8e6a2b3c9d10
# Server-side OpenAI key used by the cron job. Prefer this over NEXT_PUBLIC_OPENAI_API_KEY for automation.
OPENAI_API_KEY=
# Tavily API key for admin /api/admin/questions/web-search (https://tavily.com).
# Use the key from the dashboard (starts with tvly-). Sent as Authorization: Bearer.
TAVILY_API_KEY=
# Optional overrides.
QUESTION_CRON_MODEL=gpt-4o-mini
# Optional. Leave empty for general frontend search across no specific company.
QUESTION_CRON_COMPANY=
QUESTION_CRON_COUNT=2
# Separate multiple topics with semicolons.
QUESTION_CRON_TOPICS=senior React frontend interview questions;frontend performance questions for large React applications;React accessibility questions for complex user interfaces
