# Public site URL (no trailing slash). Used for canonical, Open Graph, sitemap, and robots.
# On Vercel you can omit this if you rely on VERCEL_URL for preview URLs; set it for your custom domain in production.
# VITE_SITE_URL=https://yourdomain.com

# Google Analytics 4 measurement ID (optional). Example: G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Gemini API key (optional, dev convenience). Prefills the Gemini field in AI settings; still exposed in the client bundle.
# VITE_GEMINI_API_KEY=AIza…

# OpenAI API key (optional, dev convenience). Prefills the OpenAI field in AI settings; still exposed in the client bundle.
# VITE_OPENAI_API_KEY=sk-…
